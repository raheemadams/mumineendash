// ════════════════════════════════════════════════════════════════════════
// MosqueOS — Prisma schema
//
// CORE PRINCIPLE: The database is the source of truth.
// Raw bank statements are stored only as evidence (RawStatementFile / Row).
// Every imported row is normalized into the Transaction ledger, which is the
// one standardized internal accounting database that powers reports,
// dashboards and reconciliation. Cash is counted exactly once.
//
// Targets PostgreSQL (Supabase). Not yet applied to a live database.
// ════════════════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────

enum Gender {
  MALE
  FEMALE
  UNSPECIFIED
}

enum MembershipStatus {
  ACTIVE
  INACTIVE
  PENDING
  SUSPENDED
  DECEASED
  MOVED_AWAY
}

enum MembershipType {
  REGULAR
  STUDENT
  SENIOR
  FAMILY
  LIFETIME
  HONORARY
}

enum DuesFrequency {
  MONTHLY
  QUARTERLY
  YEARLY
  CUSTOM
}

enum DuesStatus {
  PAID
  UPCOMING
  PAST_DUE
  GRACE_PERIOD
  SUSPENDED
}

enum PaymentMethod {
  CASH
  CHECK
  BANK_TRANSFER
  PAYPAL
  ZELLE
  ACH
  WIRE
  CREDIT_CARD
  DEBIT_CARD
  SQUARE
  STRIPE
  OTHER
}

enum AccountType {
  CHECKING
  SAVINGS
  CASH_BOX
  PETTY_CASH
  INVESTMENT
  PAYPAL
  MERCHANT
  OTHER
}

// Direction of money relative to the mosque.
enum TxnDirection {
  INFLOW
  OUTFLOW
  TRANSFER
}

// How a ledger row entered the system.
enum TxnSource {
  IMPORT // normalized from a bank statement
  MANUAL // hand-entered (cash collection, correction)
  DONATION // posted from a recorded donation
  DUES // posted from a recorded dues payment
  DEPOSIT // generated from a cash deposit batch
  SYSTEM // generated by the platform
}

// Reconciliation lifecycle of a ledger row.
enum ReconStatus {
  UNRECONCILED
  PENDING
  RECONCILED
  EXCLUDED // intentionally not part of reconciliation (e.g. internal transfer leg)
}

enum ImportStatus {
  UPLOADED
  PARSED
  MAPPED
  NORMALIZED
  COMMITTED
  FAILED
}

enum DepositStatus {
  PENDING_BANK_DEPOSIT // collected, sitting with the admin
  DEPOSITED // physically taken to the bank, awaiting statement
  RECONCILED // matched to a bank transaction
  CANCELLED
}

enum AttributionType {
  MEMBER
  FAMILY
  GUEST
  ANONYMOUS
  CAMPAIGN
  EVENT
  FUND
}

enum NotificationType {
  MEMBERSHIP_EXPIRED
  DEPOSIT_AWAITING_RECONCILIATION
  STATEMENT_IMPORTED
  DUPLICATE_DETECTED
  LARGE_DONATION
  FAILED_IMPORT
  UPCOMING_RENEWAL
  OUTSTANDING_BALANCE
}

// ─────────────────────────────────────────────────────────────────────────
// IDENTITY, ROLES & PERMISSIONS  (RBAC)
// ─────────────────────────────────────────────────────────────────────────

// Mirrors a Supabase auth.users row. authId links to auth.uid().
model User {
  id        String   @id @default(uuid())
  authId    String?  @unique // supabase auth user id
  email     String   @unique
  fullName  String
  avatarUrl String?
  isActive  Boolean  @default(true)
  mfaEnabled Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  roles            UserRole[]
  auditLogs        AuditLog[]
  notifications    Notification[]
  createdTxns      Transaction[]    @relation("TxnCreatedBy")
  enteredDeposits  DepositBatch[]   @relation("DepositCreatedBy")
  importBatches    ImportBatch[]
  pastoralNotes    PastoralNote[]   @relation("PastoralAuthor")
  linkedMember     Member?          @relation("MemberUser")

  @@index([email])
}

model Role {
  id          String   @id @default(uuid())
  key         String   @unique // president, treasurer, imam, ...
  name        String
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())

  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id          String  @id @default(uuid())
  key         String  @unique // members.read, transactions.write, reports.export ...
  description String?

  roles RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

// ─────────────────────────────────────────────────────────────────────────
// MEMBERSHIP & FAMILIES
// ─────────────────────────────────────────────────────────────────────────

model Family {
  id            String   @id @default(uuid())
  familyName    String
  primaryEmail  String?
  primaryPhone  String?
  addressLine1  String?
  addressLine2  String?
  city          String?
  state         String?
  postalCode    String?
  country       String?  @default("USA")
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  members       Member[]
  duesPlans     DuesPlan[]
  donations     Donation[]
  transactions  Transaction[]

  @@index([familyName])
}

model Member {
  id               String           @id @default(uuid())
  memberCode       String           @unique // MUM-0001
  userId           String?          @unique
  user             User?            @relation("MemberUser", fields: [userId], references: [id])

  firstName        String
  lastName         String
  // denormalized for fast search / fuzzy matching
  fullName         String
  familyId         String?
  family           Family?          @relation(fields: [familyId], references: [id])
  relationshipToHead String?        // head, spouse, child, dependent

  email            String?
  phone            String?
  gender           Gender           @default(UNSPECIFIED)
  dateOfBirth      DateTime?
  addressLine1     String?
  addressLine2     String?
  city             String?
  state            String?
  postalCode       String?
  country          String?          @default("USA")

  emergencyContactName  String?
  emergencyContactPhone String?

  occupation       String?
  skills           String[]         @default([])
  volunteerInterests String[]       @default([])
  committees       String[]         @default([])

  membershipStatus MembershipStatus @default(ACTIVE)
  membershipType   MembershipType   @default(REGULAR)
  dateJoined       DateTime         @default(now())
  photoUrl         String?
  notes            String?

  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  duesPlans        DuesPlan[]
  duesPayments     DuesPayment[]
  donations        Donation[]
  transactions     Transaction[]
  pastoralNotes    PastoralNote[]

  @@index([fullName])
  @@index([lastName])
  @@index([membershipStatus])
  @@index([familyId])
}

// ─────────────────────────────────────────────────────────────────────────
// MEMBERSHIP DUES
// ─────────────────────────────────────────────────────────────────────────

model DuesPlan {
  id          String        @id @default(uuid())
  memberId    String?
  member      Member?       @relation(fields: [memberId], references: [id])
  familyId    String?
  family      Family?       @relation(fields: [familyId], references: [id])

  frequency   DuesFrequency @default(MONTHLY)
  amount      Decimal       @db.Decimal(12, 2)
  startDate   DateTime
  endDate     DateTime?
  graceDays   Int           @default(15)
  status      DuesStatus    @default(UPCOMING)
  isActive    Boolean       @default(true)

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  payments    DuesPayment[]

  @@index([memberId])
  @@index([familyId])
  @@index([status])
}

model DuesPayment {
  id          String   @id @default(uuid())
  duesPlanId  String
  duesPlan    DuesPlan @relation(fields: [duesPlanId], references: [id], onDelete: Cascade)
  memberId    String?
  member      Member?  @relation(fields: [memberId], references: [id])

  periodStart DateTime
  periodEnd   DateTime
  amount      Decimal  @db.Decimal(12, 2)
  paidOn      DateTime?
  status      DuesStatus @default(UPCOMING)
  receiptNo   String?  @unique

  // links into the ledger once the money is accounted for
  transactionId String? @unique
  transaction   Transaction? @relation(fields: [transactionId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([memberId])
  @@index([status])
  @@index([periodStart])
}

// ─────────────────────────────────────────────────────────────────────────
// DONATIONS
// ─────────────────────────────────────────────────────────────────────────

model DonationCategory {
  id          String     @id @default(uuid())
  key         String     @unique // general, zakat, sadaqah, building_fund ...
  name        String
  description String?
  isTaxDeductible Boolean @default(true)
  isActive    Boolean    @default(true)
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())

  donations   Donation[]
}

// User-managed "purpose of the money" list picked per ledger row
// (Transaction.category stores the chosen name as a plain string). `kind`
// controls which directions a purpose is offered for: INCOME | EXPENSE | BOTH.
model LedgerCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  kind      String   @default("BOTH") // INCOME | EXPENSE | BOTH
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Donation {
  id            String           @id @default(uuid())
  categoryId    String
  category      DonationCategory @relation(fields: [categoryId], references: [id])

  amount        Decimal          @db.Decimal(12, 2)
  donatedOn     DateTime
  method        PaymentMethod    @default(CASH)
  isAnonymous   Boolean          @default(false)
  note          String?
  receiptNo     String?          @unique

  // attribution (any of these may be set — see DonationAttribution for full fan-out)
  memberId      String?
  member        Member?          @relation(fields: [memberId], references: [id])
  familyId      String?
  family        Family?          @relation(fields: [familyId], references: [id])
  campaignId    String?
  campaign      Campaign?        @relation(fields: [campaignId], references: [id])
  eventId       String?
  event         Event?           @relation(fields: [eventId], references: [id])
  fundId        String?
  fund          Fund?            @relation(fields: [fundId], references: [id])

  // link to the standardized ledger
  transactionId String?          @unique
  transaction   Transaction?     @relation(fields: [transactionId], references: [id])

  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([categoryId])
  @@index([memberId])
  @@index([donatedOn])
}

// ─────────────────────────────────────────────────────────────────────────
// CAMPAIGNS, EVENTS, FUNDS (donation targets)
// ─────────────────────────────────────────────────────────────────────────

model Campaign {
  id          String     @id @default(uuid())
  name        String
  description String?
  goalAmount  Decimal?   @db.Decimal(12, 2)
  startDate   DateTime?
  endDate     DateTime?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())

  donations   Donation[]
}

model Event {
  id          String     @id @default(uuid())
  name        String
  description String?
  startsAt    DateTime?
  endsAt      DateTime?
  location    String?
  createdAt   DateTime   @default(now())

  donations   Donation[]
}

model Fund {
  id          String     @id @default(uuid())
  name        String
  description String?
  isRestricted Boolean   @default(false)
  createdAt   DateTime   @default(now())

  donations   Donation[]
}

// ─────────────────────────────────────────────────────────────────────────
// FINANCIAL ACCOUNTS
// ─────────────────────────────────────────────────────────────────────────

model FinancialAccount {
  id              String       @id @default(uuid())
  name            String // "Bank of America — Operating"
  institution     String?
  type            AccountType  @default(CHECKING)
  accountMask     String? // last 4
  currency        String       @default("USD")
  openingBalance  Decimal      @db.Decimal(14, 2) @default(0)
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  transactions    Transaction[]
  importBatches   ImportBatch[]
  depositBatches  DepositBatch[]
  importMappings  ImportMapping[]

  @@index([type])
}

// ─────────────────────────────────────────────────────────────────────────
// STATEMENT IMPORT — raw evidence (never shown as truth)
// ─────────────────────────────────────────────────────────────────────────

model RawStatementFile {
  id           String       @id @default(uuid())
  importBatchId String      @unique
  importBatch  ImportBatch  @relation(fields: [importBatchId], references: [id], onDelete: Cascade)

  fileName     String
  mimeType     String?
  byteSize     Int?
  storagePath  String? // supabase storage object path
  sha256       String? // dedupe identical uploads
  createdAt    DateTime     @default(now())

  rows         RawStatementRow[]
}

// One untouched row exactly as parsed from the source file. Evidence only.
model RawStatementRow {
  id          String           @id @default(uuid())
  fileId      String
  file        RawStatementFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  rowIndex    Int
  raw         Json // original column->value map
  createdAt   DateTime         @default(now())

  transaction Transaction? // the normalized row this produced (if committed)

  @@index([fileId])
}

// A saved field map so a given account/source only needs mapping once.
model ImportMapping {
  id          String   @id @default(uuid())
  name        String
  accountId   String?
  account     FinancialAccount? @relation(fields: [accountId], references: [id])
  sourceHint  String? // "bank_of_america", "paypal" ...
  // maps internal field -> source column header
  // { date, description, amount, debit, credit, reference }
  fieldMap    Json
  dateFormat  String?  // e.g. MM/DD/YYYY
  amountStyle String?  @default("single") // single | debit_credit
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  importBatches ImportBatch[]
}

model ImportBatch {
  id           String       @id @default(uuid())
  accountId    String
  account      FinancialAccount @relation(fields: [accountId], references: [id])
  mappingId    String?
  mapping      ImportMapping?   @relation(fields: [mappingId], references: [id])
  createdById  String?
  createdBy    User?        @relation(fields: [createdById], references: [id])

  status       ImportStatus @default(UPLOADED)
  source       String? // detected source key
  rowCount     Int          @default(0)
  importedCount Int         @default(0)
  duplicateCount Int        @default(0)
  errorMessage String?

  createdAt    DateTime     @default(now())
  committedAt  DateTime?

  rawFile      RawStatementFile?
  transactions Transaction[]

  @@index([accountId])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────────
// THE LEDGER — standardized internal transactions (SOURCE OF TRUTH)
// ─────────────────────────────────────────────────────────────────────────

model Transaction {
  id              String       @id @default(uuid())
  accountId       String
  account         FinancialAccount @relation(fields: [accountId], references: [id])

  date            DateTime
  amount          Decimal      @db.Decimal(14, 2) // always positive
  direction       TxnDirection
  // convenience signed columns for reporting
  deposit         Decimal?     @db.Decimal(14, 2)
  withdrawal      Decimal?     @db.Decimal(14, 2)

  description     String?
  memo            String?
  referenceNumber String?
  category        String?
  paymentMethod   PaymentMethod?

  source          TxnSource    @default(IMPORT)
  reconStatus     ReconStatus  @default(UNRECONCILED)

  // provenance
  importBatchId   String?
  importBatch     ImportBatch? @relation(fields: [importBatchId], references: [id])
  rawRowId        String?      @unique
  rawRow          RawStatementRow? @relation(fields: [rawRowId], references: [id])
  createdById     String?
  createdBy       User?        @relation("TxnCreatedBy", fields: [createdById], references: [id])

  // duplicate detection
  dedupeHash      String? // amount|date|account|ref fingerprint
  duplicateScore  Float?       @default(0)
  confidenceScore Float?       @default(1)
  isDuplicate     Boolean      @default(false)
  duplicateOfId   String?
  duplicateOf     Transaction? @relation("TxnDuplicate", fields: [duplicateOfId], references: [id])
  duplicates      Transaction[] @relation("TxnDuplicate")

  // attribution (denormalized convenience FKs; full fan-out in DonationAttribution)
  memberId        String?
  member          Member?      @relation(fields: [memberId], references: [id])
  familyId        String?
  family          Family?      @relation(fields: [familyId], references: [id])

  // reconciliation link to a cash deposit batch
  depositBatchId  String?
  depositBatch    DepositBatch? @relation(fields: [depositBatchId], references: [id])

  importedAt      DateTime     @default(now())
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  donation        Donation?
  duesPayment     DuesPayment?

  @@index([accountId])
  @@index([date])
  @@index([direction])
  @@index([reconStatus])
  @@index([dedupeHash])
  @@index([memberId])
  @@index([importBatchId])
  @@index([isDuplicate])
}

// ─────────────────────────────────────────────────────────────────────────
// CASH DEPOSIT WORKFLOW — count the money exactly once
// ─────────────────────────────────────────────────────────────────────────

model DepositBatch {
  id           String        @id @default(uuid())
  depositCode  String        @unique // 2026-001
  accountId    String? // destination bank account
  account      FinancialAccount? @relation(fields: [accountId], references: [id])
  createdById  String?
  createdBy    User?         @relation("DepositCreatedBy", fields: [createdById], references: [id])

  status       DepositStatus @default(PENDING_BANK_DEPOSIT)
  expectedTotal Decimal      @db.Decimal(14, 2) @default(0)
  depositedOn  DateTime?
  reconciledOn DateTime?
  notes        String?

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  items        DepositBatchItem[]
  // the single bank transaction this batch reconciles against
  transactions Transaction[]

  @@index([status])
}

model DepositBatchItem {
  id          String        @id @default(uuid())
  batchId     String
  batch       DepositBatch  @relation(fields: [batchId], references: [id], onDelete: Cascade)

  method      PaymentMethod @default(CASH)
  amount      Decimal       @db.Decimal(12, 2)
  description String?
  // optional attribution of this slice of cash to a member/family
  memberId    String?
  familyId    String?
  evidenceUrl String? // zelle screenshot, check image
  createdAt   DateTime      @default(now())

  @@index([batchId])
}

// ─────────────────────────────────────────────────────────────────────────
// DONATION ATTRIBUTION FAN-OUT
// One transaction/donation can belong to member + family + campaign + event
// simultaneously. This join table records every attribution edge.
// ─────────────────────────────────────────────────────────────────────────

model DonationAttribution {
  id            String          @id @default(uuid())
  transactionId String
  type          AttributionType
  targetId      String? // member/family/campaign/event/fund id (null for ANONYMOUS)
  weight        Decimal?        @db.Decimal(5, 4) // split share, defaults to full
  createdAt     DateTime        @default(now())

  @@index([transactionId])
  @@index([type, targetId])
}

// ─────────────────────────────────────────────────────────────────────────
// PASTORAL (IMAM) RECORDS — private
// ─────────────────────────────────────────────────────────────────────────

model PastoralNote {
  id         String   @id @default(uuid())
  memberId   String?
  member     Member?  @relation(fields: [memberId], references: [id])
  authorId   String?
  author     User?    @relation("PastoralAuthor", fields: [authorId], references: [id])

  kind       String // visit, funeral, marriage, shahada, counseling, prayer_request
  title      String
  body       String?
  isPrivate  Boolean  @default(true)
  occurredOn DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([memberId])
  @@index([kind])
}

// ─────────────────────────────────────────────────────────────────────────
// AUDIT LOG — track everything, no silent deletes
// ─────────────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id])

  action     String // create, update, delete, login, export ...
  entityType String // Member, Transaction, DepositBatch ...
  entityId   String?
  oldValue   Json?
  newValue   Json?
  reason     String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────────────────────────────────

model Notification {
  id         String           @id @default(uuid())
  userId     String?
  user       User?            @relation(fields: [userId], references: [id])
  type       NotificationType
  title      String
  body       String?
  entityType String?
  entityId   String?
  isRead     Boolean          @default(false)
  createdAt  DateTime         @default(now())

  @@index([userId, isRead])
  @@index([type])
}
